{
  "name": "maps-deleted-reviews",
  "version": "0.3.0",
  "description": "Config-driven Playwright scraper for Google Maps deleted-review notices.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "maps-deleted-reviews": "dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "dev": "tsx src/index.ts --config config.example.json"
  },
  "keywords": [
    "google-maps",
    "playwright",
    "scraper",
    "reviews"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
